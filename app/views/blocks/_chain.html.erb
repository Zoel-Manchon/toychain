<% pending = local_assigns.fetch(:pending, 0) %>
<% chain_valid = first_invalid.nil? %>

<%# Línea de estado de la cadena %>
<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
  <p class="text-sm text-indigo-400/70">
    <span class="text-sky-400 glow-accent">$</span> <span class="cursor-blink">chain --status</span>
  </p>
  <% if chain_valid %>
    <span class="inline-flex w-fit items-center gap-2 rounded-full border border-violet-500/30 bg-violet-500/10 px-3 py-1 text-xs font-semibold text-violet-400">
      <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
      CHAIN VALID · <%= blocks.size %> BLOCKS
    </span>
  <% else %>
    <span class="inline-flex w-fit items-center gap-2 rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-400">
      <span class="h-1.5 w-1.5 rounded-full bg-red-400 animate-pulse"></span>
      CHAIN CORRUPTED
    </span>
  <% end %>
</div>

<%# Cadena de bloques %>
<% if blocks.empty? && pending.zero? %>
  <div class="rounded-lg border border-dashed border-indigo-700/60 px-6 py-12 text-center">
    <p class="text-indigo-400/70 text-sm">// empty chain</p>
    <p class="mt-2 text-indigo-300/80">Mine the genesis block to begin.</p>
  </div>
<% else %>
  <ol class="space-y-0">
    <% blocks.each_with_index do |block, i| %>
      <% broken = first_invalid && i >= first_invalid %>
      <li>
        <% if i.positive? %>
          <div class="ml-6 h-6 w-px bg-gradient-to-b <%= first_invalid && i > first_invalid ? "from-red-500/40 to-red-500/40" : "from-slate-700 to-sky-500/40" %>"></div>
        <% end %>

        <div class="rounded-lg border p-3 sm:p-4 transition-colors <%= broken ? "border-red-500/50 bg-red-950/25" : "border-indigo-700/50 bg-indigo-950/50 hover:border-sky-500/40" %>">
          <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between">
            <h2 class="font-semibold glow-accent <%= broken ? "text-red-400" : "text-sky-400" %>">
              block #<%= block.block_index %>
              <% if broken %><span class="text-xs font-normal text-red-500 ml-2">[INVALID]</span><% end %>
            </h2>
            <time class="text-xs text-indigo-400/70"><%= block.mined_at&.strftime("%Y-%m-%d %H:%M:%S") %></time>
          </div>

          <p class="mt-2 text-sm break-words <%= broken ? "text-red-300" : "text-indigo-200" %>"><%= block.data %></p>

          <dl class="mt-3 grid gap-1 text-xs">
            <div class="flex gap-2 min-w-0">
              <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">hash</dt>
              <dd class="truncate <%= broken ? "text-red-400/80" : "text-violet-400/80" %>"><%= block.block_hash %></dd>
            </div>
            <div class="flex gap-2 min-w-0">
              <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">prev</dt>
              <dd class="text-indigo-400/70 truncate"><%= block.previous_hash %></dd>
            </div>
            <div class="flex gap-2">
              <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">nonce</dt>
              <dd class="text-indigo-300/80"><%= block.nonce %></dd>
            </div>
            <div class="flex gap-2">
              <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">diff</dt>
              <dd class="text-indigo-300/80"><%= block.difficulty %></dd>
            </div>
            <% if block.mined_ms %>
              <div class="flex gap-2">
                <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">mined in</dt>
                <dd class="text-sky-400/70"><%= block.mined_ms %> ms</dd>
              </div>
            <% end %>
            <% if block.user %>
              <div class="flex gap-2 min-w-0">
                <dt class="text-indigo-400/70 shrink-0 w-12 sm:w-16">mined by</dt>
                <dd class="text-violet-400/80 truncate"><%= block.user.email_address %></dd>
              </div>
            <% end %>
          </dl>

          <div class="mt-3 flex justify-end">
            <%= button_to "☠ tamper", tamper_block_path(block),
                  class: "cursor-pointer rounded border border-indigo-700/60 px-2 py-1 text-xs text-indigo-400/70 hover:border-red-500/50 hover:text-red-400 transition-colors" %>
          </div>
        </div>
      </li>
    <% end %>

    <%# Trabajos de minado en curso: barra animada por cada uno %>
    <% pending.times do %>
      <li>
        <% if blocks.any? %>
          <div class="ml-6 h-6 w-px bg-gradient-to-b from-slate-700 to-sky-500/40"></div>
        <% end %>
        <%= render "blocks/mining" %>
      </li>
    <% end %>
  </ol>
<% end %>
