<%= form_with(model: block, class: "contents") do |form| %>
  <% if block.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(block.errors.count, "error") %> prohibited this block from being saved:</h2>

      <ul class="list-disc ml-6">
        <% block.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :block_index %>
    <%= form.number_field :block_index, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:block_index].none?, "border-red-400 focus:outline-red-600": block.errors[:block_index].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :data %>
    <%= form.textarea :data, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:data].none?, "border-red-400 focus:outline-red-600": block.errors[:data].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :previous_hash %>
    <%= form.text_field :previous_hash, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:previous_hash].none?, "border-red-400 focus:outline-red-600": block.errors[:previous_hash].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :block_hash %>
    <%= form.text_field :block_hash, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:block_hash].none?, "border-red-400 focus:outline-red-600": block.errors[:block_hash].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :nonce %>
    <%= form.number_field :nonce, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:nonce].none?, "border-red-400 focus:outline-red-600": block.errors[:nonce].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :mined_at %>
    <%= form.datetime_field :mined_at, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:mined_at].none?, "border-red-400 focus:outline-red-600": block.errors[:mined_at].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
