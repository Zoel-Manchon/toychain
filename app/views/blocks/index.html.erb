<main class="max-w-3xl mx-auto px-3 py-6 sm:px-4 sm:py-12">
  <%= turbo_stream_from "chain" %>

  <%# Ventana de terminal %>
  <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 shadow-2xl shadow-slate-950/60 overflow-hidden">

    <%# Barra de título %>
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/70 border-b border-slate-700/60">
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="ml-3 text-xs text-slate-500 tracking-wide truncate">toychain — block explorer</span>
    </div>

    <div class="p-4 sm:p-6 space-y-5 sm:space-y-6">

      <%# Diana de los broadcasts: la cadena en vivo %>
      <div id="chain" class="space-y-5 sm:space-y-6">
        <%= render "chain", blocks: @blocks, first_invalid: @first_invalid, pending: @pending %>
      </div>

      <%# Acciones de la cadena %>
      <div class="pt-2 flex flex-wrap items-center gap-3">
        <%= link_to new_block_path,
              class: "inline-flex items-center gap-2 rounded-lg border border-fuchsia-500/40 bg-fuchsia-500/10 px-4 py-2 text-sm font-semibold text-fuchsia-400 hover:bg-fuchsia-500/20 transition-colors" do %>
          <span>$</span> mine --new-block
        <% end %>

        <% if @blocks.any? %>
          <%= button_to "$ chain --reset", reset_blocks_path, method: :delete,
                data: { turbo_confirm: "Wipe the entire chain?" },
                class: "cursor-pointer rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-500 hover:border-rose-500/50 hover:text-rose-400 transition-colors" %>
        <% end %>

        <%# Sesión, empujada a la derecha %>
        <div class="ml-auto flex items-center gap-3">
          <span class="hidden sm:inline text-xs text-slate-600"><%= Current.user&.email_address %></span>
          <%= button_to "$ logout", session_path, method: :delete,
                class: "cursor-pointer rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-500 hover:border-fuchsia-500/50 hover:text-fuchsia-400 transition-colors" %>
        </div>
      </div>

    </div>
  </div>
</main>
