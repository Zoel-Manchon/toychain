<main class="max-w-3xl mx-auto px-4 py-12">
  <%# Ventana de terminal %>
  <div class="rounded-xl border border-zinc-800 bg-zinc-900/70 shadow-2xl shadow-black/50 overflow-hidden">

    <%# Barra de título %>
    <div class="flex items-center gap-2 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
      <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
      <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
      <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
      <span class="ml-3 text-xs text-zinc-500 tracking-wide">toychain — block explorer</span>
    </div>

    <div class="p-6 space-y-6">

      <%# Línea de estado de la cadena %>
      <div class="flex items-center justify-between">
        <p class="text-sm text-zinc-500">
          <span class="text-amber-500 glow-amber">$</span> <span class="cursor-blink">chain --status</span>
        </p>
        <% if @chain_valid %>
          <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-400">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            CHAIN VALID · <%= @blocks.size %> BLOCKS
          </span>
        <% else %>
          <span class="inline-flex items-center gap-2 rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-400">
            <span class="h-1.5 w-1.5 rounded-full bg-red-400 animate-pulse"></span>
            CHAIN CORRUPTED
          </span>
        <% end %>
      </div>

      <%# Cadena de bloques %>
      <% if @blocks.empty? %>
        <div class="rounded-lg border border-dashed border-zinc-800 px-6 py-12 text-center">
          <p class="text-zinc-500 text-sm">// empty chain</p>
          <p class="mt-2 text-zinc-400">Mine the genesis block to begin.</p>
        </div>
      <% else %>
        <ol class="space-y-0">
          <% @blocks.each_with_index do |block, i| %>
            <li>
              <% if i.positive? %>
                <div class="ml-6 h-6 w-px bg-gradient-to-b from-zinc-700 to-amber-500/40"></div>
              <% end %>

              <div class="rounded-lg border border-zinc-800 bg-zinc-950/60 p-4 hover:border-amber-500/40 transition-colors">
                <div class="flex items-baseline justify-between">
                  <h2 class="text-amber-400 font-semibold glow-amber">
                    block #<%= block.block_index %>
                  </h2>
                  <time class="text-xs text-zinc-600"><%= block.mined_at&.strftime("%Y-%m-%d %H:%M:%S") %></time>
                </div>

                <p class="mt-2 text-sm text-zinc-300 break-words"><%= block.data %></p>

                <dl class="mt-3 grid gap-1 text-xs">
                  <div class="flex gap-2">
                    <dt class="text-zinc-600 shrink-0 w-16">hash</dt>
                    <dd class="text-emerald-400/80 truncate"><%= block.block_hash %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-zinc-600 shrink-0 w-16">prev</dt>
                    <dd class="text-zinc-500 truncate"><%= block.previous_hash %></dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-zinc-600 shrink-0 w-16">nonce</dt>
                    <dd class="text-zinc-400"><%= block.nonce %></dd>
                  </div>
                </dl>
              </div>
            </li>
          <% end %>
        </ol>
      <% end %>

      <%# Prompt para minar %>
      <div class="pt-2">
        <%= link_to new_block_path,
              class: "inline-flex items-center gap-2 rounded-lg border border-amber-500/40 bg-amber-500/10 px-4 py-2 text-sm font-semibold text-amber-400 hover:bg-amber-500/20 transition-colors" do %>
          <span>$</span> mine --new-block
        <% end %>
      </div>

    </div>
  </div>
</main>