<main class="max-w-2xl mx-auto px-3 py-6 sm:px-4 sm:py-12">
  <div class="rounded-xl border border-slate-700/60 bg-slate-800/40 shadow-2xl shadow-slate-950/60 overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/70 border-b border-slate-700/60">
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="h-3 w-3 rounded-full bg-slate-600"></span>
      <span class="ml-3 text-xs text-slate-500 tracking-wide">toychain — mine</span>
    </div>

    <div class="p-4 sm:p-6">
      <p class="text-sm text-slate-500 mb-4">
        <span class="text-fuchsia-400 glow-accent">$</span> <span class="cursor-blink">mine --interactive</span>
      </p>

      <%= form_with model: @block, class: "space-y-4" do |form| %>
        <% if @block.errors.any? %>
          <div class="rounded-lg border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-400">
            <% @block.errors.full_messages.each do |msg| %>
              <p>✗ <%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= form.label :data, "block data", class: "block text-xs text-slate-500 mb-1" %>
          <%= form.text_area :data, rows: 4, autofocus: true,
                placeholder: "payload to store in this block...",
                class: "w-full rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 text-sm text-slate-200 placeholder-slate-600 focus:border-fuchsia-500/50 focus:outline-none focus:ring-1 focus:ring-fuchsia-500/30" %>
        </div>

        <div>
          <%= form.label :difficulty, "difficulty (leading zeros)", class: "block text-xs text-slate-500 mb-1" %>
          <%= form.select :difficulty,
                options_for_select(ProofOfWork::DIFFICULTY_RANGE.map { |d| [ "#{d} — #{"0" * d}…", d ] }, 4),
                {},
                class: "w-full rounded-lg border border-slate-700 bg-slate-950/60 px-3 py-2 text-sm text-slate-200 focus:border-fuchsia-500/50 focus:outline-none focus:ring-1 focus:ring-fuchsia-500/30" %>
        </div>

        <div class="flex items-center gap-3">
          <%= form.submit "⛏ mine block",
                class: "cursor-pointer rounded-lg border border-fuchsia-500/40 bg-fuchsia-500/10 px-4 py-2 text-sm font-semibold text-fuchsia-400 hover:bg-fuchsia-500/20 transition-colors" %>
          <%= link_to "cancel", blocks_path, class: "text-sm text-slate-600 hover:text-slate-400" %>
        </div>
      <% end %>
    </div>
  </div>
</main>
