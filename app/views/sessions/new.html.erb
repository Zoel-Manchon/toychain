<main class="max-w-md mx-auto px-3 py-6 sm:px-4 sm:py-12">
  <div class="rounded-xl border border-indigo-700/50 bg-indigo-900/40 shadow-2xl shadow-indigo-950/80 overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 bg-indigo-900/60 border-b border-indigo-700/50">
      <span class="h-3 w-3 rounded-full bg-indigo-700"></span>
      <span class="h-3 w-3 rounded-full bg-indigo-700"></span>
      <span class="h-3 w-3 rounded-full bg-indigo-700"></span>
      <span class="ml-3 text-xs text-indigo-400/70 tracking-wide">toychain — authenticate</span>
    </div>

    <div class="p-4 sm:p-6">
      <p class="text-sm text-indigo-400/70 mb-4">
        <span class="text-sky-400 glow-accent">$</span> <span class="cursor-blink">login --interactive</span>
      </p>

      <%= form_with url: session_path, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :email_address, "email", class: "block text-xs text-indigo-400/70 mb-1" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
                placeholder: "operator@toychain.dev",
                class: "w-full rounded-lg border border-indigo-700/60 bg-indigo-950/60 px-3 py-2 text-sm text-indigo-100 placeholder-indigo-400/40 focus:border-sky-500/50 focus:outline-none focus:ring-1 focus:ring-sky-500/30" %>
        </div>

        <div>
          <%= form.label :password, class: "block text-xs text-indigo-400/70 mb-1" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password",
                placeholder: "••••••••", maxlength: 72,
                class: "w-full rounded-lg border border-indigo-700/60 bg-indigo-950/60 px-3 py-2 text-sm text-indigo-100 placeholder-indigo-400/40 focus:border-sky-500/50 focus:outline-none focus:ring-1 focus:ring-sky-500/30" %>
        </div>

        <div class="flex items-center justify-between gap-3">
          <%= form.submit "→ authenticate",
                class: "cursor-pointer rounded-lg border border-sky-500/40 bg-sky-500/10 px-4 py-2 text-sm font-semibold text-sky-400 hover:bg-sky-500/20 transition-colors" %>
          <%= link_to "forgot password?", new_password_path, class: "text-xs text-indigo-400/50 hover:text-indigo-300/80" %>
        </div>
      <% end %>

      <p class="mt-6 pt-4 border-t border-indigo-700/50 text-xs text-indigo-400/70">
        no operator account?
        <%= link_to "$ register", new_registration_path, class: "text-violet-400 hover:text-violet-300" %>
      </p>
    </div>
  </div>
</main>
